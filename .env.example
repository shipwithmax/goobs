# ─────────────────────────────────────────────────────────────────
#   MaxShip Video Editor — environment config
# ─────────────────────────────────────────────────────────────────
#
#   Copy this file to `.env` and fill in only what you need.
#   The ship runs entirely offline by default — no keys required
#   to transcribe, cut, render, or animate. Add keys only to unlock
#   the optional cloud features below.
#
#   Run `vp init` to set this up interactively.
#

# ── WHERE YOUR VIDEOS LIVE ───────────────────────────────────────
#   Default: ./hangar (next to this repo). Each video gets its own
#   folder, e.g. hangar/Y26-04-25-my-first-video/.
PROJECTS_ROOT=./hangar


# ── TRANSCRIPTION ────────────────────────────────────────────────
#   Default: NVIDIA Parakeet V2 — runs locally, free, private.
#   First run downloads the model (~1.2 GB). No internet after that.
#
#   If Parakeet's setup gives you trouble, the tool gracefully falls
#   back to faster-whisper, then whisper.cpp, then cloud APIs (if
#   you've added a key for one).
#
#   Options:
#     parakeet-local    — fastest, English-only, native word timestamps
#     faster-whisper    — multilingual, light Python install
#     whisper-cloud     — OpenAI Whisper API (needs OPENAI_API_KEY)
#     elevenlabs-scribe — multilingual, emotion tags (needs ELEVENLABS_API_KEY)
#     deepgram          — best filler-word detection (needs DEEPGRAM_API_KEY)
#
TRANSCRIBER=parakeet-local

# Only fill the matching key below if you switch to a cloud option:
OPENAI_API_KEY=
DEEPGRAM_API_KEY=


# ── ELEVENLABS — UNLOCKS THREE FEATURES AT ONCE ──────────────────
#   Adding an ElevenLabs key turns on:
#     1. ElevenLabs Scribe transcription (alt to Parakeet/Whisper)
#     2. Voice cloning for B-roll narration in stage 3 (Enrich)
#     3. SFX & music generation for transitions in stage 3
#     4. Audio cleanup / voice isolation in stage 4 (Polish)
#
#   One key, four superpowers. Get yours at https://elevenlabs.io/app/settings/api-keys
#
ELEVENLABS_API_KEY=


# ── SOCIAL SCHEDULING (optional) ─────────────────────────────────
#   Get your key at: https://app.zernio.com/settings/api
#   Skip this if you only want to render videos locally.
#
#   By default, scheduled posts are saved as DRAFTS for your review.
#   Set SCHEDULE_AUTO_PUBLISH=true to skip the human-in-the-loop step
#   (not recommended unless you trust the pipeline 100%).
#
ZERNIO_API_KEY=
SCHEDULE_AUTO_PUBLISH=false


# ── DIRECTOR-CUE EXTRACTION (optional) ───────────────────────────
#   Turns "editor add a chart here" spoken on-camera into a
#   structured cue the motion graphics stage can act on.
#
#   Default uses a small local pattern matcher — no key needed.
#   Set DIRECTOR_LLM=claude or =openai for smarter cue extraction.
#
DIRECTOR_LLM=local
ANTHROPIC_API_KEY=


# ── LOG LEVEL ────────────────────────────────────────────────────
#   debug | info | warn | error
LOG_LEVEL=info
